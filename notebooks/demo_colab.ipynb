   "source": ["# XTTS-v2 Darija Marocain — Demo Colab\n",
               "Fine-tuning et génération vocale en Darija marocain"]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": ["# ÉTAPE 1 — Installation\n",
               "!pip install -q coqui-tts soundfile gradio datasets faster-whisper jiwer\n",
               "!apt-get install -y ffmpeg -q"]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": ["# ÉTAPE 2 — Cloner le repo\n",
               "!git clone https://github.com/chaimaehde/xtts-darija.git\n",
               "%cd xtts-darija"]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": ["# ÉTAPE 3 — Préparer les données\n",
               "import sys; sys.path.append(\'/content/xtts-darija\')\n",
               "from data.prepare_dataset import prepare_all\n",
               "prepare_all(n_samples=650, output_dir=\'/content/doda_darija\')"]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": ["# ÉTAPE 4 — Finetuner (nécessite GPU T4)\n",
               "from training.finetune import finetune\n",
               "finetune(\n",
               "    data_path   = \'/content/doda_darija\',\n",
               "    model_dir   = \'/root/.local/share/tts/tts_models--multilingual--multi-dataset--xtts_v2/\',\n",
               "    output_path = \'/content/outputs\',\n",
               "    epochs      = 5,\n",
               ")"]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": ["# ÉTAPE 5 — Charger le modèle finetuné\n",
               "from inference.generate import load_model\n",
               "model, config = load_model(\n",
               "    checkpoint_path = \'/content/outputs/best_model.pth\',\n",
               "    config_path     = \'/content/outputs/config.json\',\n",
               "    vocab_path      = \'/root/.local/share/tts/tts_models--multilingual--multi-dataset--xtts_v2/vocab.json\',\n",
               ")"]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": ["# ÉTAPE 6 — Générer un audio\n",
               "from inference.generate import generate\n",
               "generate(\n",
               "    model       = model,\n",
               "    config      = config,\n",
               "    text        = \'مرحبا، كيف داير؟ واش كلشي مزيان؟\',\n",
               "    speaker_wav = \'/content/doda_darija/wavs/utt_0000.wav\',\n",
               "    output_path = \'/content/test_output.wav\',\n",
               ")\n",
               "from IPython.display import Audio\n",
               "Audio(\'/content/test_output.wav\')"]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": ["# ÉTAPE 7 — Lancer l\'interface Gradio\n",
               "from interface.gradio_app import launch_interface\n",
               "launch_interface(model, config, share=True)"]
  }
